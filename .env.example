# Sportsense Configuration
# This file contains environment variables for the Sportsense application.

# Copy this file to .env and fill in your values.

# =============================================================================
# QDRANT VECTOR DATABASE
# =============================================================================
# Qdrant host URL (local or remote)
QDRANT_HOST=localhost

# Qdrant REST API port
QDRANT_PORT=6333

# Qdrant gRPC port (optional, for advanced usage)
QDRANT_GRPC_PORT=6334

# Qdrant API key (if authentication is enabled, leave empty for local)
QDRANT_API_KEY=your_key_here

# Qdrant collection name for UEFA rankings embeddings
QDRANT_COLLECTION_RANKINGS=uefa_rankings_embeddings

# Qdrant collection name for match data embeddings
QDRANT_COLLECTION_MATCHES=uefa_matches_embeddings

# Vector size for embeddings (must match your embedding model output)
# granite-embedding-278m-multilingual outputs 768 dimensions
QDRANT_VECTOR_SIZE=768

# Distance metric for vector search (Cosine, Euclid, Dot)
QDRANT_DISTANCE_METRIC=Cosine
